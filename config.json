{
  "feeds": ["quant-ph"],

  "include_replacements": false,

  "cross_allow_primary": [
    "quant-ph",
    "cs.IT", "cs.CR", "cs.CC", "cs.ET", "cs.DS", "cs.LG",
    "cs.AR", "cs.PL", "cs.LO", "cs.DC",
    "math.QA", "math-ph", "math.OA", "math.IT", "math.PR",
    "math.CO", "math.RT", "math.NA",
    "physics.atom-ph", "physics.optics", "physics.app-ph",
    "cond-mat.mes-hall", "cond-mat.supr-con", "cond-mat.quant-gas",
    "eess.SP", "stat.ML"
  ],

  "cross_deny_primary": [],

  "translators": ["gemini", "deepl", "google"],
  "classify_with_llm": true,
  "gemini_model": "gemini-2.0-flash",
  "gemini_min_interval_sec": 7,
  "gemini_max_retries": 4,
  "gemini_overload_giveup": 2,
  "translate_batch_size": 5,
  "max_translate_chars": 2000,
  "translate_only_matched": false,
  "require_translation": true,
  "show_original_abstract": false,

  "genres": [
    {
      "id": "qec",
      "name": "誤り訂正・符号理論",
      "description": "量子誤り訂正符号の設計・解析。安定化符号、表面符号、トーリック符号、カラー符号、LDPC符号、ボゾン符号、CSS構成。デコーダの設計・解析・閾値定理。符号距離・論理演算子の最適化など。フォールトトレラント実装は ft へ。",
      "webhook_env": "DISCORD_WEBHOOK_QEC",
      "keywords": [
        "error correction", "error-correct", "stabilizer code", "surface code",
        "toric code", "color code", "ldpc code", "qec", "repetition code",
        "bosonic code", "css code", "quantum code", "decoder", "decoding",
        "code distance", "threshold theorem", "minimum distance"
      ]
    },
    {
      "id": "ft",
      "name": "フォールトトレラント計算",
      "description": "フォールトトレラント量子計算の理論と方式。マジックステート蒸留・注入、論理ゲートの実装(transversal gate, code switching, lattice surgery)、ユニバーサルゲートセット、資源推定、concatenated符号によるFT。誤り訂正符号自体の設計は qec へ。",
      "webhook_env": "DISCORD_WEBHOOK_FT",
      "keywords": [
        "fault-tolerant", "fault tolerance", "magic state", "magic state distillation",
        "logical qubit", "logical gate", "transversal gate", "lattice surgery",
        "code switching", "resource estimation", "universal fault-tolerant",
        "flag qubit", "concatenated code", "magic state injection"
      ]
    },
    {
      "id": "algo",
      "name": "量子アルゴリズム",
      "description": "具体的な量子アルゴリズムの設計・解析・改善。Grover探索、Shorの素因数分解、量子ウォーク、量子フーリエ変換、位相推定、HHL、振幅増幅、量子サンプリング、線形代数アルゴリズムなど。複雑性クラスや下界の理論は complexity へ。変分系は nisq へ。",
      "webhook_env": "DISCORD_WEBHOOK_ALGO",
      "keywords": [
        "quantum algorithm", "grover", "shor", "quantum walk", "quantum speedup",
        "quantum advantage", "amplitude amplification", "quantum phase estimation",
        "hhl", "quantum fourier transform", "quantum sampling", "quantum search",
        "quantum linear system", "quantum signal processing", "qubitization"
      ]
    },
    {
      "id": "complexity",
      "name": "量子複雑性理論",
      "description": "量子計算複雑性の理論的研究。BQP・QMA・QIP・MQIPなどの複雑性クラスの解析、オラクル分離、クエリ複雑性の下界、量子PCP定理、局所ハミルトニアン問題、対話型証明、量子回路の複雑性など。",
      "webhook_env": "DISCORD_WEBHOOK_COMPLEXITY",
      "keywords": [
